{
    "name": "popover-widget",
    "version": "1.0.0",
    "description": "Pure JavaScript popover widget without jQuery",
    "main": "src/popover.js",
    "scripts": {
      "start": "webpack serve --mode development --open",
      "build": "webpack --mode production",
      "test": "jest",
      "test:coverage": "jest --coverage",
      "test:puppeteer": "jest tests/popover.puppeteer.test.js --runInBand",
      "lint": "eslint src/**/*.js",
      "prepare": "husky install"
    },
    "keywords": ["popover", "javascript", "widget", "bootstrap", "vanilla-js"],
    "author": "",
    "license": "ISC",
    "devDependencies": {
      "@babel/core": "^7.23.2",
      "@babel/preset-env": "^7.23.2",
      "babel-jest": "^29.7.0",
      "babel-loader": "^9.1.3",
      "css-loader": "^6.8.1",
      "eslint": "^8.51.0",
      "eslint-config-airbnb-base": "^15.0.0",
      "eslint-plugin-import": "^2.28.1",
      "html-webpack-plugin": "^5.5.3",
      "husky": "^8.0.3",
      "jest": "^29.7.0",
      "jest-environment-jsdom": "^29.7.0",
      "lint-staged": "^15.0.2",
      "puppeteer": "^21.4.0",
      "style-loader": "^3.3.3",
      "webpack": "^5.89.0",
      "webpack-cli": "^5.1.4",
      "webpack-dev-server": "^4.15.1"
    },
    "jest": {
      "transform": {
        "^.+\\.js$": "babel-jest"
      },
      "testEnvironment": "jsdom",
      "moduleNameMapper": {
        "\\.css$": "<rootDir>/tests/__mocks__/styleMock.js"
      },
      "collectCoverageFrom": [
        "src/**/*.js",
        "!src/**/*.test.js"
      ],
      "coveragePathIgnorePatterns": [
        "/node_modules/",
        "/tests/"
      ],
      "coverageThreshold": {
        "global": {
          "branches": 80,
          "functions": 80,
          "lines": 80,
          "statements": 80
        }
      }
    },
    "lint-staged": {
      "*.js": [
        "eslint --fix",
        "jest --findRelatedTests --passWithNoTests"
      ]
    }
  }